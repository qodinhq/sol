{
  "name": "@qodin-co/sol",
  "version": "0.2.0",
  "type": "module",
  "description": "Solar-aware React widget library with real-time phase transitions.",
  "repository": {
    "type": "git",
    "url": "https://github.com/qodin-co/sol"
  },
  "license": "MIT",
  "author": "qodin",
  "keywords": [
    "react",
    "solar",
    "widget",
    "sun",
    "theme",
    "clock"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./devtools": {
      "default": "./dist/devtools/index.js",
      "types": "./dist/devtools/index.d.ts"
    },
    "./styles.css": "./dist/styles.css",
    "./styles-no-preflight.css": "./dist/styles-no-preflight.css"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsdown && bunx @tailwindcss/cli -i src/styles.css -o dist/styles.css --minify && bunx @tailwindcss/cli -i src/styles-no-preflight.css -o dist/styles-no-preflight.css --minify",
    "dev": "concurrently \"tsdown --watch\" \"bunx @tailwindcss/cli -i src/styles.css -o dist/styles.css --watch\"",
    "typecheck": "tsc --noEmit --pretty",
    "lint": "biome check --error-on-warnings ./src",
    "format": "biome format --write .",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "dependencies": {
    "@paper-design/shaders-react": "^0.0.71",
    "@types/tz-lookup": "^6.1.2",
    "@usefy/use-geolocation": "^0.2.4",
    "@usefy/use-local-storage": "^0.2.5",
    "@usefy/use-session-storage": "^0.2.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "countries-and-timezones": "^3.6.0",
    "country-flag-icons": "^1.5.13",
    "i18n-iso-countries": "^7.13.0",
    "motion": "^11.0.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "tz-lookup": "^6.1.25"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@tailwindcss/cli": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.6",
    "@types/react-dom": "^18.3.0",
    "concurrently": "^9.0.0",
    "tailwindcss": "^4.0.0",
    "tsdown": "^0.15.9",
    "typescript": "^5.7.0"
  },
  "packageManager": "bun@1.2.16"
}
